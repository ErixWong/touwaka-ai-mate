# Touwaka Mate - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 数据库配置（必填）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=touwaka_mate
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# 服务器配置
PORT=3000

# 数据目录配置
DATA_BASE_PATH=./data
WORKSPACE_ROOT=./data/work
KB_IMAGES_ROOT=./data/kb-images

# JWT 配置（生产环境必填！建议使用 32 位以上随机字符串）
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key

# Python 可执行文件路径
PYTHON_PATH=python3

# 日志级别：debug, info, warn, error
LOG_LEVEL=info
